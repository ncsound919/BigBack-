# ── BackendMCP environment variables ─────────────────────────────────────────
# Copy this file to .env and fill in the values before running docker compose.

# REQUIRED – generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# PostgreSQL (must match if you override the defaults below)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=myservice

# Full DSN – update this if you change POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/myservice

# Redis
REDIS_URL=redis://redis:6379/0

# App environment: development | staging | production
ENV=production
